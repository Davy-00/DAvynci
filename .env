DRY_RUN=false
TRADING_PROFILE=aggressive

# Use current logged-in MT5 terminal session when credentials are not provided.
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

SYMBOLS=EURUSD,GBPUSD,USDJPY,AUDUSD,NZDUSD,USDCHF,EURCHF,GOLD

MIN_QUALITY_SCORE=3.40
MAX_NEW_ENTRIES_PER_CYCLE=2
MAX_POSITIONS_TOTAL=3
MAX_NEW_TRADES_PER_DAY=12
MAX_CONSECUTIVE_LOSSES=2

RISK_PER_TRADE_PCT=1.00
USE_PROFIT_RISK_SCALING=true
PROFIT_RISK_STEP_PCT=5.0
PROFIT_RISK_INCREMENT_PCT=0.25
MAX_RISK_PER_TRADE_PCT=2.60

DAILY_LOSS_LIMIT_PCT=4.00

# Keep bot active regardless of London/NY windows.
ONLY_TRADE_LONDON_NEWYORK=false

MAX_MT5_FAILURES_BEFORE_HALT=3
MAX_STALE_DATA_CYCLES_BEFORE_HALT=100
MAX_DATA_STALENESS_MINUTES=20
MAX_UNHANDLED_ERRORS_BEFORE_HALT=3
REQUIRE_MARKET_CONNECTION=true

NEWS_EVENTS_FILE=news_events.csv
