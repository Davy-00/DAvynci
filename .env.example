# Copy to .env and edit values
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Server
MT5_PATH=

# One-switch profile mode: growth or aggressive
# TRADING_PROFILE=growth

# Comma-separated exact broker symbols to trade
# SYMBOLS=GOLD,GBPJPY,EURUSD,BTCUSD,USDJPY

# Example 20-pair FX universe (exact names verified on your broker)
# SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,USDCAD,AUDUSD,NZDUSD,EURGBP,EURJPY,GBPJPY,EURCHF,GBPCHF,EURAUD,EURNZD,AUDJPY,CADJPY,CHFJPY,AUDCAD,AUDNZD,NZDJPY

# Higher win-rate default basket used in config (keeps GOLD, excludes weaker pairs)
# SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,NZDUSD,EURJPY,GOLD

# Replaced weak links default basket (adds EURCHF, CADJPY, BTCUSD)
# SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,NZDUSD,EURCHF,CADJPY,BTCUSD,GOLD

# Trend-trading compatible basket (majors + momentum crosses + gold + bitcoin)
# SYMBOLS=EURUSD,GBPUSD,USDJPY,AUDUSD,NZDUSD,USDCHF,EURJPY,GBPJPY,GOLD,BTCUSD

# Global cap on simultaneous open bot positions
# MAX_POSITIONS_TOTAL=1

# Quality-first selection controls
# MIN_QUALITY_SCORE=2.8
# MAX_NEW_ENTRIES_PER_CYCLE=2
# Optional pair-specific extra quality offsets are configured in config.py
# Example idea: weaker pairs can require higher score than base MIN_QUALITY_SCORE

# Recommended quality-first live profile for 20 pairs
# MIN_QUALITY_SCORE=3.8
# MAX_NEW_ENTRIES_PER_CYCLE=1
# MAX_POSITIONS_TOTAL=2

# Aggressive profile (higher return potential, higher drawdown risk)
# MIN_QUALITY_SCORE=3.2
# MAX_NEW_ENTRIES_PER_CYCLE=2
# MAX_POSITIONS_TOTAL=3
# MAX_NEW_TRADES_PER_DAY=10

# Realistic growth profile (targeting steadier monthly growth)
# RISK_PER_TRADE_PCT=0.45
# USE_PROFIT_RISK_SCALING=true
# PROFIT_RISK_STEP_PCT=10.0
# PROFIT_RISK_INCREMENT_PCT=0.10
# MAX_RISK_PER_TRADE_PCT=1.20
# DAILY_LOSS_LIMIT_PCT=2.50
# MIN_QUALITY_SCORE=3.3
# MAX_NEW_TRADES_PER_DAY=8
# MAX_POSITIONS_TOTAL=2

# Aggressive profile defaults (activated by TRADING_PROFILE=aggressive)
# RISK_PER_TRADE_PCT=0.90
# DAILY_LOSS_LIMIT_PCT=4.00
# MIN_QUALITY_SCORE=3.1
# MAX_NEW_TRADES_PER_DAY=12
# MAX_POSITIONS_TOTAL=3

# Safety toggles
DRY_RUN=true

# Optional: custom path to CSV news calendar used by news filter
NEWS_EVENTS_FILE=news_events.csv

# Optional live-safety guard overrides (conservative example values)
# MAX_NEW_TRADES_PER_DAY=4
# MAX_CONSECUTIVE_LOSSES=2
# MAX_MT5_FAILURES_BEFORE_HALT=3
# MAX_STALE_DATA_CYCLES_BEFORE_HALT=3
# MAX_DATA_STALENESS_MINUTES=20
# MAX_UNHANDLED_ERRORS_BEFORE_HALT=3
# REQUIRE_MARKET_CONNECTION=true

# Optional: publish signals to Vercel webhook
# SIGNALS_WEBHOOK_ENABLED=true
# SIGNALS_WEBHOOK_URL=https://your-vercel-app.vercel.app/api/ingest
# SIGNALS_WEBHOOK_TOKEN=change_me_long_random_secret
